APP_NAME="Japa Treinador"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Sao_Paulo
APP_URL=https://api.japatreinador.com.br
FRONTEND_URL=https://japatreinador.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=japa_treinador
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.japatreinador.com.br
SESSION_SAME_SITE=strict

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=japa_treinador_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@japatreinador.com.br"
MAIL_FROM_NAME="Japa Treinador"

# Sanctum
SANCTUM_STATEFUL_DOMAINS=japatreinador.com.br,www.japatreinador.com.br
SANCTUM_TOKEN_EXPIRATION=60

# CORS
CORS_ALLOWED_ORIGINS=https://japatreinador.com.br,https://www.japatreinador.com.br

# Cloudinary
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=japa_treinador_secure
CLOUDINARY_MAX_FILE_SIZE=5242880

# Infinity Pay
INFINITYPAY_SECRET_KEY=
INFINITYPAY_WEBHOOK_SECRET=
INFINITYPAY_API_URL=https://api.infinitepay.io/v3
INFINITYPAY_ENVIRONMENT=production

# Security
RATE_LIMIT_LOGIN=5
RATE_LIMIT_REGISTER=3
RATE_LIMIT_API=60
INFINITYPAY_ALLOWED_IPS=
