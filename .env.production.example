APP_NAME="Japa Treinador"
APP_ENV=production
APP_KEY=          # gerar com: php artisan key:generate --show
APP_DEBUG=false
APP_TIMEZONE=America/Sao_Paulo
APP_URL=https://api.seudominio.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR

BCRYPT_ROUNDS=12

LOG_CHANNEL=single
LOG_LEVEL=error

# ── BANCO (usar credenciais do cPanel → MySQL Databases) ──
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=riansa90_japa_treinador
DB_USERNAME=riansa90_japa_user
DB_PASSWORD=senha_forte_aqui

SESSION_DRIVER=database
SESSION_LIFETIME=60
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.seudominio.com.br
SESSION_SAME_SITE=strict

QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local

# ── SANCTUM ──
SANCTUM_STATEFUL_DOMAINS=seudominio.com.br,www.seudominio.com.br
SANCTUM_TOKEN_EXPIRATION=60

# ── CORS ── (domínio do Vercel ou seu domínio)
CORS_ALLOWED_ORIGINS=https://seudominio.com.br,https://www.seudominio.com.br

# ── CLOUDINARY ──
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# ── INFINITY PAY ──
INFINITYPAY_SECRET_KEY=sua_chave
INFINITYPAY_WEBHOOK_SECRET=seu_webhook_secret
INFINITYPAY_API_URL=https://api.infinitepay.io/v3

RATE_LIMIT_LOGIN=5
RATE_LIMIT_REGISTER=3
RATE_LIMIT_API=60
